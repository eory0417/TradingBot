# =============================================================================
#  Binance USDⓈ-M Futures News Trading Bot - Environment Variables
# -----------------------------------------------------------------------------
#  Copy this file to ".env" and fill in your real credentials.
#  NEVER commit the real ".env" file to version control.
# =============================================================================

# ---- Binance API (USDⓈ-M Futures) ----
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# ---- Telegram Bot (alert sending) ----
TELEGRAM_TOKEN=123456789:your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ---- Telegram user session (coinnesskr news receiving via Telethon) ----
# Separate from the alert bot above. Get API_ID / API_HASH at https://my.telegram.org
# Required only when NEWS_SOURCE_MODE includes coinnesskr.
# Run `python telegram_login.py` once to create the session file before first use.
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
# Session file name (without extension); stored as models/<name>.session
TELEGRAM_SESSION_NAME=tradingbot_plus
# Telegram channel username to receive (without @). ko: coinnesskr / en: coinnessGL
COINNESS_CHANNEL=coinnessGL
# Channel language: ko (Korean, translated before analysis) | en (English, analyzed as-is)
COINNESS_LANG=en

# ---- Runtime options ----
# Demo trading mode (true) vs live mainnet (false).
#   true  -> demo.binance.com API keys (paper trading, no real funds)
#   false -> binance.com API keys (REAL money — use with caution)
# Note: the old Futures testnet/sandbox is deprecated; ccxt uses Demo Trading instead.
BINANCE_TESTNET=true

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Directory where rotating log files are written.
LOG_DIR=logs

# ---- News ingestion & NLP (Stage 2) ----
# News source mode: rss | coinnesskr | rss_coinnesskr | cryptopanic
#   rss            -> built-in RSS feeds only
#   coinnesskr     -> Telegram @coinnesskr only (requires TELEGRAM_API_ID/HASH + session)
#   rss_coinnesskr -> both RSS and coinnesskr (default)
#   cryptopanic    -> CryptoPanic API only (requires CRYPTOPANIC_API_TOKEN)
NEWS_SOURCE_MODE=rss_coinnesskr

# Optional. Get a free token at https://cryptopanic.com/developers/api/
# Used only when NEWS_SOURCE_MODE=cryptopanic.
CRYPTOPANIC_API_TOKEN=

# Optional comma-separated RSS URL override (blank = built-in 16+ free feeds).
NEWS_RSS_FEEDS=

# News polling cadence in seconds (>= 10). Default 60 = once per minute.
NEWS_POLL_INTERVAL=60
# Seconds after bot start before news can trigger entries (RSS warmup + grace).
NEWS_ENTRY_GRACE_SEC=60
# Max article age (minutes) for entry — older published_at is ignored.
NEWS_MAX_AGE_MINUTES=30
# Warmup: how many recent RSS headlines to show in GUI (entries still gated separately).
NEWS_WARMUP_DISPLAY_LIMIT=30

# Hugging Face sentiment model (institutional, finance-tuned).
FINBERT_MODEL=ProsusAI/finbert

# CPU threads for torch inference (0 = auto / all cores).
TORCH_NUM_THREADS=0

# ---- Trading engine (Stage 3) ----
# Target coins (comma-separated). 'BTC' is expanded to 'BTC/USDT'.
TRADE_SYMBOLS=BTC,ETH,SOL,XRP

# Candle timeframe for RSI/ATR/slope.
TIMEFRAME=15m

# Maximum simultaneous open positions.
MAX_POSITIONS=2

# Marketable-limit order fill condition: IOC or FOK.
ORDER_TIME_IN_FORCE=IOC

# Notional value per entry (USDT).
POSITION_SIZE_USDT=50

# Leverage multiplier (used when AUTO_LEVERAGE=false / manual mode).
LEVERAGE=3

# Auto leverage by news-score strength (true) vs manual slider (false).
#   |score| 0.7->1x, 0.8->2x, 0.9->3x, 1.0->4x.
#   When |score|==1.0 but slope is counter-direction, still enter at 2x.
AUTO_LEVERAGE=true

# Margin mode: isolated | cross
MARGIN_MODE=isolated

# ---- Take-profit / stop-loss strategy (Stage 4) ----
# Fixed stop-loss percentage (market close when hit).
STOP_LOSS_PCT=2.0
# Trailing-stop base ATR multiple.
TRAILING_ATR_MULT=3.0
# Tightened ATR multiple under strong trend/news signals.
TRAILING_ATR_MULT_TIGHT=1.5
# Minimum unrealized profit (%) before trailing stop activates.
TRAILING_PROFIT_PCT=2.0
# News score trigger threshold (positive 0.7 / negative -0.7).
NEWS_SCORE_THRESHOLD=0.7
# Sideways time-exit holding window (hours).
TIME_EXIT_HOURS=7.0
# Position monitoring interval (seconds).
MONITOR_INTERVAL=15

# ---- FinBERT periodic fine-tuning (auto re-training) ----
# Enable monthly automatic re-training of the sentiment model.
FINETUNE_ENABLED=true
# Re-training cadence in days (30 = once per month).
FINETUNE_INTERVAL_DAYS=30
# Minimum accumulated samples required before training runs.
FINETUNE_MIN_SAMPLES=50
# Max recent samples used per training run (caps time/memory on CPU).
FINETUNE_MAX_SAMPLES=1000
# Training epochs (keep small on CPU).
FINETUNE_EPOCHS=1
# Directory to save/load the fine-tuned model (relative to project root).
FINETUNE_DIR=models/finbert-finetuned
